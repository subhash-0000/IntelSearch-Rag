# Flask
FLASK_ENV=development
SECRET_KEY=replace-me

# Retrieval and generation tuning
RAG_TOP_K=8
RAG_RERANK_TOP_K=4
RAG_CHUNK_SIZE=700
RAG_CHUNK_OVERLAP=120

# Optional: turn on lightweight HF generation (slower first run)
RAG_ENABLE_HF_GENERATOR=false
RAG_HF_MODEL=google/flan-t5-base

# Optional domain filter preset (e.g. engineering, hr, policy)
RAG_DEFAULT_DOMAIN=
